{
    "installCommand": "npm install && npm rebuild argon2",
    "buildCommand": "prisma migrate deploy && next build",
    "crons": [
        {
            "path": "/api/cron/update-prices",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/sync-payments",
            "schedule": "*/10 * * * *"
        }
    ]
}

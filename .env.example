# Database
DATABASE_URL="postgresql://user:password@localhost:5432/helmac?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Auth.js for public users
PUBLIC_JWT_SECRET="generate-with-openssl-rand-base64-32"

# App
NODE_ENV="development"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Public user auth (separate from admin)
PUBLIC_JWT_SECRET="generate-with-openssl-rand-base64-32"

# SMTP (confirmation emails)
SMTP_HOST="smtp.seznam.cz"
SMTP_PORT="465"
SMTP_USER="your-email@seznam.cz"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@seznam.cz"

# Vercel only (auto-set when Blob store is linked)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

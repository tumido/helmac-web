# Database
DATABASE_URL="postgresql://user:password@localhost:5432/helmac?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Auth.js for public users
PUBLIC_JWT_SECRET="generate-with-openssl-rand-base64-32"

# App
NODE_ENV="development"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Encryption key for email account passwords (AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here-generate-with-openssl-rand-hex-32ok"

# Vercel only (auto-set when Blob store is linked)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Cron price validation curl -H "Authorization: Bearer <secret>" http://localhost:3000/api/cron/update-prices
CRON_SECRET="generate-with-openssl-rand-base64-32"

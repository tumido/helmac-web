// Helmac Web - Database Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTH - Users and sessions
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(EDITOR)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  createdNews   News[]    @relation("NewsAuthor")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ============================================
// EMAIL ACCOUNTS - SMTP email accounts
// ============================================

model EmailAccount {
    id                String   @id @default(cuid())
    email             String   @unique
    encryptedPassword String
    isMain            Boolean  @default(false)
    label             String?

    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    confirmationYears Year[] @relation("ConfirmationEmail")
    priceChangeYears  Year[] @relation("PriceChangeEmail")

    @@map("email_accounts")
}

// ============================================
// YEARS - Main organizational unit
// ============================================

model Year {
  id          String      @id @default(cuid())
  year        Int         @unique
  title       String
  subtitle    String?
  isActive    Boolean     @default(false)
  isArchived  Boolean     @default(false)

  startDate   DateTime?
  endDate     DateTime?

  headerPhoto String?
  heroPhoto   String?

  registrationOpen      Boolean   @default(false)
  registrationStartDate DateTime?

  confirmationEmailEnabled  Boolean  @default(false)
  confirmationEmailSubject  String?
  confirmationEmailBody     String?  @db.Text
  confirmationEmailBcc      String?
  confirmationEmailAccountId  String?
  confirmationEmailAccount    EmailAccount? @relation("ConfirmationEmail", fields: [confirmationEmailAccountId], references: [id], onDelete: SetNull)

  priceChangeEmailEnabled  Boolean  @default(false)
  priceChangeEmailSubject  String?
  priceChangeEmailBody     String?  @db.Text
  priceChangeEmailBcc      String?
  priceChangeEmailAccountId  String?
  priceChangeEmailAccount    EmailAccount? @relation("PriceChangeEmail", fields: [priceChangeEmailAccountId], references: [id], onDelete: SetNull)

  bankAccountPrefix   String?
  bankAccountNumber   String?
  bankAccountBankCode String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pages         Page[]
  news          News[]
  albums        Album[]
  registrationForm        RegistrationForm?
  registrationSubmissions RegistrationSubmission[]
  programDays   ProgramDay[]
  rules         Rule[]
  offers        Offer[]
  infoSections  InfoSection[]

  @@map("years")
}

// ============================================
// PROGRAM - Schedule for events
// ============================================

model ProgramDay {
  id        String   @id @default(cuid())
  yearId    String
  year      Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)

  date      DateTime
  label     String   // "Den 1", "Patek", etc.
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    ProgramEvent[]

  @@unique([yearId, date])
  @@map("program_days")
}

model ProgramEvent {
  id           String     @id @default(cuid())
  dayId        String
  day          ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  startTime    String     // "13:00" format
  title        String
  description  String     @db.Text
  location     String
  imageUrl     String?
  tags         String[]   // Array of tag strings
  storyContent Json?      // Rich content for detail modal

  isPublished  Boolean    @default(false)
  sortOrder    Int        @default(0)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("program_events")
}

// ============================================
// RULES - Pravidla sections per year
// ============================================

model Rule {
    id        String   @id @default(cuid())
    yearId    String
    year      Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)

    title     String
    content   String   @db.Text
    sortOrder Int      @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("rules")
}

// ============================================
// OFFERS - Co nabízíme sections per year
// ============================================

model Offer {
    id        String   @id @default(cuid())
    yearId    String
    year      Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)

    title     String
    content   String   @db.Text
    sortOrder Int      @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("offers")
}

// ============================================
// INFO SECTIONS - Info tab sections per year
// ============================================

model InfoSection {
    id        String   @id @default(cuid())
    yearId    String
    year      Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)

    title     String
    content   String   @db.Text
    sortOrder Int      @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("info_sections")
}

// ============================================
// PAGES - Individual page content
// ============================================

model Page {
  id          String      @id @default(cuid())
  yearId      String
  year        Year        @relation(fields: [yearId], references: [id], onDelete: Cascade)

  slug        String
  title       String

  content     Json        @default("{}")

  seoTitle    String?
  seoDesc     String?

  isPublished Boolean     @default(false)
  sortOrder   Int         @default(0)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([yearId, slug])
  @@map("pages")
}

// ============================================
// NEWS - Blog/updates
// ============================================

model News {
  id          String      @id @default(cuid())
  yearId      String
  year        Year        @relation(fields: [yearId], references: [id], onDelete: Cascade)

  authorId    String
  author      User        @relation("NewsAuthor", fields: [authorId], references: [id])

  slug        String
  title       String
  excerpt     String?
  content     String      @db.Text
  coverImage  String?

  isPublished Boolean     @default(false)
  publishedAt DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([yearId, slug])
  @@map("news")
}

// ============================================
// MEDIA - Gallery and images
// ============================================

model Album {
  id          String      @id @default(cuid())
  yearId      String
  year        Year        @relation(fields: [yearId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?
  coverImage  String?
  externalUrl String

  sortOrder   Int         @default(0)
  isPublished Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([yearId, slug])
  @@map("albums")
}

// ============================================
// AUDIT LOG - Track changes
// ============================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String
  changes     Json?

  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

// ============================================
// PUBLIC USERS - Self-service accounts
// ============================================

model PublicUser {
    id              String    @id @default(cuid())
    email           String    @unique
    passwordHash    String
    emailVerified   Boolean   @default(false)
    emailVerifiedAt DateTime?
    gdprConsentAt   DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    verificationTokens  EmailVerificationToken[]
    passwordResetTokens PasswordResetToken[]
    registrations       RegistrationSubmission[]

    @@map("public_users")
}

model EmailVerificationToken {
    id        String     @id @default(cuid())
    token     String     @unique
    userId    String
    user      PublicUser @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime   @default(now())

    @@map("email_verification_tokens")
}

model PasswordResetToken {
    id        String     @id @default(cuid())
    token     String     @unique
    userId    String
    user      PublicUser @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime   @default(now())

    @@map("password_reset_tokens")
}

// ============================================
// REGISTRATION - Dynamic form-based registration
// ============================================

model RegistrationForm {
    id        String   @id @default(cuid())
    yearId    String   @unique
    year      Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
    fields    Json     // Array of FormField definitions
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    submissions RegistrationSubmission[]

    @@map("registration_forms")
}

model RegistrationSubmission {
    id              String   @id @default(cuid())
    yearId          String
    year            Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
    formId          String
    form            RegistrationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
    publicUserId    String?
    publicUser      PublicUser? @relation(fields: [publicUserId], references: [id], onDelete: SetNull)
    data            Json     // { [fieldName]: value }
    status          RegistrationStatus @default(PENDING)
    isPaid          Boolean  @default(false)
    paidAt          DateTime?
    pricingSummary  Json?    // { tiers: [{tierDate, totalPrice}], applicableTierIndex, totalPrice }
    variableSymbol  String?  @unique // 10-digit random numeric string
    totalPrice      Int?     // applicable total at submission time (CZK)
    emailSent       Boolean  @default(false)
    emailSentAt     DateTime?
    adminNote       String?   @db.Text
    gdprConsentAt   DateTime?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@map("registration_submissions")
}

// ============================================
// SITE SETTINGS - Site-wide key-value settings
// ============================================

model SiteSetting {
    id        String   @id @default(cuid())
    key       String   @unique
    value     String   @db.Text
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("site_settings")
}

enum RegistrationStatus {
    PENDING
    CONFIRMED
    WAITLIST
    CANCELLED
    REJECTED
}

{
  "name": "helmac-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && node lib/icons/build-registry.mjs && next build",
    "postinstall": "prisma generate && node lib/icons/build-registry.mjs",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:dump": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' prisma/scripts/dump-seed-data.ts",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "migrate:html-to-md": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' prisma/scripts/migrate-html-to-markdown.ts",
    "migrate:content-to-blocks": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' prisma/scripts/migrate-content-to-blocks.ts",
    "migrate:blob-to-r2": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' prisma/scripts/migrate-blob-urls.ts",
    "icons:build": "node lib/icons/build-registry.mjs"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1046.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/material-nextjs": "^5.18.0",
    "@mui/x-date-pickers": "^8.27.2",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-details": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-youtube": "^3.22.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "argon2": "^0.44.0",
    "dayjs": "^1.11.20",
    "jose": "^6.2.1",
    "next": "^16.1.0",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.2",
    "notistack": "^3.0.2",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "slugify": "^1.6.6",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "use-debounce": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.1.0",
    "postcss": "^8",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
